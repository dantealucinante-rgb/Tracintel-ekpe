// Simplified Prisma schema for Tracintel intelligence platform
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PlanTier {
  STARTER
  GROWTH
  PRO
  SCALE
}

enum LlmProvider {
  GPT4
  CLAUDE
  GEMINI
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Organization {
  id          String           @id @default(cuid())
  name        String
  plan        PlanTier         @default(STARTER)
  scanLimit   Int              @default(120)
  scansUsed   Int              @default(0)
  strategyContext String?
  createdAt   DateTime         @default(now())
  profiles    Profile[]
  scans       VisibilityScan[]
  dataSources DataSource[]
}

model Profile {
  id             String       @id @default(cuid())
  userId         String       @unique // Maps to Supabase auth.users.id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  email          String       @unique
  createdAt      DateTime     @default(now())
}

model VisibilityScan {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  dataSourceId   String?
  dataSource     DataSource?   @relation(fields: [dataSourceId], references: [id])
  brand          String
  industry       String
  competitors    String[]
  status           ScanStatus     @default(PENDING)
  strategyInjected Boolean        @default(false)
  completedAt      DateTime?
  createdAt        DateTime       @default(now())
  raw_passes       Json?
  llmResponses     LlmResponse[]
  signals          Signal[]
  signalPushes     SignalPush[]
}

model DataSource {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  name           String
  type           String
  config         Json
  createdAt      DateTime         @default(now())
  scans          VisibilityScan[]
}

model LlmResponse {
  id        String         @id @default(cuid())
  scanId    String
  scan      VisibilityScan @relation(fields: [scanId], references: [id])
  provider     LlmProvider
  providerUsed String?
  rawText      String
  createdAt    DateTime       @default(now())
}

model Signal {
  id               String         @id @default(cuid())
  scanId           String
  scan             VisibilityScan @relation(fields: [scanId], references: [id])
  mentionFrequency Float
  citationDensity  Float
  sentimentScore   Float
  latentDensity    Float
  createdAt        DateTime       @default(now())
}

enum PushStatus {
  PENDING
  EXECUTED
  FAILED
}

model SignalPush {
  id             String         @id @default(cuid())
  scanId           String
  scan             VisibilityScan @relation(fields: [scanId], references: [id])
  targetPlatform String         @default("SHOPIFY")
  status           PushStatus     @default(PENDING)
  payload          Json
  executedAt       DateTime?
  createdAt        DateTime       @default(now())
}
