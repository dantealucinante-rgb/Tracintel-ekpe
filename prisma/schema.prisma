// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PlanTier {
  STARTER
  GROWTH
  PRO
  SCALE
}

model Organization {
  id                   String         @id @default(cuid())
  name                 String
  slug                 String         @unique
  planTier             PlanTier       @default(STARTER)
  monthlyAnalysisLimit Int            @default(120)
  modelAccess          String[]       @default([])
  usageCount           Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  profiles             Profile[]
  dataSources          DataSource[]
  scans                VisibilityScan[]
}

model Profile {
  id             String       @id // This matches Supabase auth.users.id
  email          String       @unique
  name           String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("profiles")
}

enum DataSourceType {
  SHOPIFY
  WEB
  CUSTOM
}

model DataSource {
  id             String         @id @default(cuid())
  type           DataSourceType
  name           String
  config         Json           // Stores credentials, shopify domain, etc.
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  scans          VisibilityScan[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model VisibilityScan {
  id             String         @id @default(cuid())
  status         ScanStatus     @default(PENDING)
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  dataSourceId   String
  dataSource     DataSource     @relation(fields: [dataSourceId], references: [id])
  responses      LlmResponse[]
  pushes         SignalPush[]
  signals        Signal[]
  createdAt      DateTime       @default(now())
  completedAt    DateTime?
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model LlmResponse {
  id               String         @id @default(cuid())
  scanId           String
  scan             VisibilityScan @relation(fields: [scanId], references: [id])
  modelName        String         // e.g., 'gpt-4', 'claude-3-opus'
  modelProvider    String         // e.g., 'openai', 'anthropic'
  prompt           String
  rawResponse      String
  structuredData   Json?          // Parsed visibility metrics
  sentimentScore   Float?
  visibilityRank   Int?
  latentDensity    Float?         // Probabilistic brand weight (0.0-1.0)
  influenceSources Json?          // URLs or fragments model prioritized
  createdAt        DateTime       @default(now())
}

model SignalPush {
  id             String         @id @default(cuid())
  scanId         String
  scan           VisibilityScan @relation(fields: [scanId], references: [id])
  targetPlatform String         // e.g., 'shopify'
  targetAction   String         // e.g., 'update_metaobject'
  payload        Json
  status         PushStatus     @default(PENDING)
  createdAt      DateTime       @default(now())
  executedAt     DateTime?
}

model Signal {
  id               String         @id @default(cuid())
  scanId           String
  scan             VisibilityScan @relation(fields: [scanId], references: [id])
  type             String         // e.g., 'MENTION', 'CITATION', 'SENTIMENT'
  source           String         // e.g., 'Reddit', 'Discord', 'Model_Inference'
  content          String
  mentionFrequency Float?
  citationDensity  Float?
  accuracyScore    Float?
  latentDensity    Float?
  metadata         Json?
  createdAt        DateTime       @default(now())

  @@map("signals")
}

enum PushStatus {
  PENDING
  SENT
  EXECUTED
  FAILED
}
